{% extends "base.html" %}
{% block title %}OAuth2 Error{% endblock %}
{% block content %}
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h4 card-title">An Error Occured</h1>
        <p class="card-text">
          {{ error }}
        </p>
        <p class="card-text text-secondary">
          {{ error_description }}
        </p>
        <a href="/" class="btn btn-primary">
          Return Home
        </a>
      </div>
    </div>
  </div>
</div>
{% endblock %}
