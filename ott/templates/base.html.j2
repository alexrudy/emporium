<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ott — {% block title %}{% endblock %}</title>
  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <link rel="stylesheet" href="/static/app.css">
  <link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
</head>
<body class="bg-body-tertiary">
  <nav class="navbar bg-body shadow-sm">
    <div class="container">
      <a class="navbar-brand" href="/">ott</a>
      <div class="d-flex align-items-center">
        {% block nav_actions %}{% endblock %}
      </div>
    </div>
  </nav>
  <main class="container py-4">
    {% block content %}{% endblock %}
  </main>
  <footer class="container py-4 text-secondary small">
    <hr>
    A reference app for the <code>oath</code> crate.
  </footer>
</body>
</html>
