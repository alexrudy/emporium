# ott — example configuration.
#
# Copy to `.env` (or wherever you keep your dev env), fill in the
# placeholders, and source it before running `cargo run -p ott`:
#
#     set -a; source .env; set +a
#     cargo run -p ott
#
# Or use direnv: rename to `.envrc` and prepend each line with `export`.
# ott itself does not parse `.env` files — it reads `std::env::var` directly.

# ─── Required: client credentials ────────────────────────────────────
# Issued by the provider when you register the application.
OAUTH_CLIENT_ID="your-client-id-here"
OAUTH_CLIENT_SECRET="your-client-secret-here"

# ─── Required: provider endpoints — pick ONE option below ────────────

# Option A — discovery (recommended for OIDC providers).
# ott fetches <issuer>/.well-known/openid-configuration at startup
# and pulls token/authorization/device endpoints from the document.
OAUTH_ISSUER="https://accounts.google.com"

# Option B — pin the URLs explicitly. Comment out OAUTH_ISSUER above
# and uncomment these for providers that don't publish a discovery
# document, or when you need to override what the document says.
# OAUTH_AUTH_URI="https://accounts.google.com/o/oauth2/v2/auth"
# OAUTH_TOKEN_URI="https://oauth2.googleapis.com/token"

# ─── Required: cookie signing key ────────────────────────────────────
# Base64-encoded, at least 64 bytes. Generate with:
#     openssl rand -base64 64 | tr -d '\n'
# Keep this out of git — the in-repo placeholder is *not* a usable key.
COOKIE_KEY="replace-me-with-openssl-rand-base64-64-output"

# ─── Optional: cosmetics ─────────────────────────────────────────────

# Display name shown on the "Sign in with X" button.
PROVIDER_NAME="Google"

# OAuth2 scopes to request. `openid` is required for the id_token-based
# identity resolver; ott adds it defensively if you forget.
OAUTH_SCOPES="openid email profile"

# ─── Optional: server runtime ────────────────────────────────────────

# Where to bind the HTTP listener.
BIND_ADDR="127.0.0.1:3000"

# Public origin the redirect URI lives under. Combined with
# `/auth/callback` to form the URL you register with the provider.
EXTERNAL_ORIGIN="http://127.0.0.1:3000"

# Where the JsonFileUserStore writes <sub>.json records.
DATA_DIR="./data"

# Set the `Secure` attribute on outgoing cookies. Must be `false` for
# `http://localhost` development; `true` (the default) for HTTPS.
SECURE_COOKIES="false"

# ─── Optional: logging ───────────────────────────────────────────────
# Standard tracing-subscriber EnvFilter syntax.
RUST_LOG="info,ott=debug,tower_http=info"

# ─── Provider cheat sheet ────────────────────────────────────────────
#
# Google
#   OAUTH_ISSUER="https://accounts.google.com"
#   Register at https://console.cloud.google.com/apis/credentials
#
# Okta (developer org)
#   OAUTH_ISSUER="https://<your-org>.okta.com/oauth2/default"
#   Register at https://<your-org>-admin.okta.com (Applications → Web)
#
# Keycloak (local docker, default realm "master")
#   OAUTH_ISSUER="http://127.0.0.1:8080/realms/master"
#   Register a confidential client in the admin console.
#
# For every provider, set the Authorized Redirect URI to
#     ${EXTERNAL_ORIGIN}/auth/callback
# — the exact match matters; a trailing slash mismatch will be rejected.
